APP_ENV=development

POSTGRES_DB=auth_cli
POSTGRES_USER=auth_cli
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgres://auth_cli:change-this-postgres-password@postgres:5432/auth_cli?sslmode=disable
REDIS_URL=redis://redis:6379/0
HISTORY_PATH=/app/data/.auth-cli-history

MIN_USERNAME_LENGTH=3
MAX_USERNAME_LENGTH=50
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=72
BCRYPT_COST=12

MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m
SESSION_TIMEOUT=30m

TOTP_ISSUER=InternshipAuthCLI
TOTP_PERIOD=30
TOTP_SKEW=1
TOTP_DIGITS=6
TOTP_SETUP_TIMEOUT=10m
TOTP_CHALLENGE_TIMEOUT=5m

# Public demonstration key for local testing only. Generate a private key for real use.
TOTP_ENCRYPTION_KEY_BASE64=tt+dC5vhHj4ghzUFiP62J31NevdTWqB7qP0merFdzu8=
