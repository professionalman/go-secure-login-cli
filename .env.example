APP_ENV=development

DATABASE_PATH=/app/data/auth.db
HISTORY_PATH=/app/data/.auth-cli-history

MIN_USERNAME_LENGTH=3
MAX_USERNAME_LENGTH=50
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=72
BCRYPT_COST=12

MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m
SESSION_TIMEOUT=30m

TOTP_ISSUER=InternshipAuthCLI
TOTP_PERIOD=30
TOTP_SKEW=1
TOTP_DIGITS=6
TOTP_SETUP_TIMEOUT=10m
TOTP_CHALLENGE_TIMEOUT=5m

# Replace this value before starting the application.
# Generate one with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY_BASE64=replace-with-base64-encoded-32-byte-key
